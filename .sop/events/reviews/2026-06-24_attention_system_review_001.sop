  + [language_readiness] is strong
  + [record_readiness] is strong
  + [index_readiness] is moderate
  + [runtime_readiness] is early
  + [debug_readiness] is moderate
  + [model_transfer_readiness] is early
  + [overall_readiness] is ready_for_minimal_scaffold_compile_runtime

