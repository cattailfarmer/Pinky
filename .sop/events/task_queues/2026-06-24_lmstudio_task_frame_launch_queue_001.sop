  + [objective] is Prepare one scratch-isolated LM Studio proposal job for Codex inspection without launching it.
  + [lane_fit] is lm_studio_cli
  + [launch_mode] is isolated
  + [status] is queue_ready
  + [ready_for_inspection] is true
  + [prompt_packet] is .sop\events\benchmarks\sop_inference_comparison_functional_prompt_20260624_007.sop
  + [launch_command] is python .sop\runtime\demos\lm_studio_agent_benchmark.py --root C:\Project\Pinky --codex-worker-prompt .sop\events\benchmarks\sop_inference_comparison_functional_prompt_20260624_007.sop --launch-mode isolated --output .sop\events\benchmarks\sop_inference_comparison_lmstudio_next_probe_20260624_008.sop --timeout 240
  + [capture_target] is .sop\events\benchmarks\sop_inference_comparison_lmstudio_next_probe_20260624_008.sop
  + [required_gates] is sop_language_primer_gate, scratch_isolation_gate, capture_gate, validator_gate, codex_review_gate, action_gate
  + [source_refs] is .sop\platform\LMStudioWorkerFunctionalLane.sop, .sop\events\operating_loop\2026-06-24_operating_loop_tick_001.sop
  + [allowed_surface] is prompt_packet, scratch_workspace, capture_target
  + [blocked_surface] is repo_mutation, credentials, destructive_action, project_root_authority
  + [block_reasons] is none
  + [outside] is automatic launch, worker file mutation, hidden model state, project-root authority, unvalidated output
  + [created_utc] is 2026-06-24T19:45:29Z
  = must: inspect launch_command before execution
  = must: capture output before validation or integration
  - never: infer launched, completed, or integrated from queue status

(task_frame_launch_queue) :task_frame_candidate: /gate_set and launch_policy/ |queue_outside|
