  + [launch_command] is python .sop\runtime\demos\lm_studio_agent_benchmark.py --root C:\Project\Pinky --codex-worker-prompt .sop\events\benchmarks\corpus_prompts\2026-06-24_task_frame_routing_prompt_012.sop --launch-mode isolated --output .sop\events\benchmarks\corpus_results\2026-06-24_task_frame_routing_result_012.sop --required-field task_subject --required-field lane_fit --required-field authority_boundary --required-field evidence_gate --required-field action_gate --required-field outside --required-field next_step --required-term lane_fit --required-term authority_boundary --required-term evidence_gate --required-term outside --forbidden-field-term "launch silently" --forbidden-field-term "credentials are safe" --forbidden-field-term "repo mutation by worker" --forbidden-field-term integrated --timeout 240
  + [capture_target] is .sop\events\benchmarks\corpus_results\2026-06-24_task_frame_routing_result_012.sop
  + [validation_profile] is node InferenceJobResult, task routing fields, required routing terms, and forbidden launch or integration overclaim terms
  + [required_gates] is sop_language_primer_gate, scratch_isolation_gate, capture_gate, validator_gate, codex_review_gate, action_gate
  + [block_reasons] is none
  + [outside] is automatic launch, worker mutation authority, hidden model state, project-root authority, broad competence claims, and unvalidated output

(task_frame_launch_queue) :task_frame_candidate: /gate_set and launch_policy/ |queue_outside|
  + [queue_status] is partially_executed
  + [completed_candidates] is corpus_boundary_delineation_010
  + [ready_candidates] is corpus_outside_preservation_011, corpus_task_frame_routing_012
  + [blocked_candidates] is none
