& [ComponentMapping] is the current frame assignment
  + [component_001_local_L3_velocity_budget] is larger_scale_velocity_norm_candidate
    = pressure_frame_slot: p_0_source_input_or_projection_remainder_input
    = admission_status: boundary_only
    = blocker: velocity_norm_input_is_not_pressure_L3_over_2_or_pressure_oscillation_output
  + [component_002_scaled_enstrophy_budget] is local_gradient_or_vorticity_energy_candidate
    = pressure_frame_slot: p_0_source_or_gradient_energy_input
