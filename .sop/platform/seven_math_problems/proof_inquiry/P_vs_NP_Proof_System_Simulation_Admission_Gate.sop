  + [simulation_direction] is operator_to_bounded_width_resolution_at_best
  + [refutation_output] is bounded_width_refutation_when_width_bound_exists
  + [proof_size_bound] is polynomial_only_if_required_width_is_controlled_by_a_named_theorem
  + [runtime_bound] is polynomial_only_in_restricted_width_scope
  + [soundness_status] is checked_in_named_proof_system_scope
  + [completeness_status] is bounded_width_only
  + [barrier_or_lower_bound_risk] is high_for_general_sat
  + [admission_status] is admitted_as_scoped_tool
  + [first_missing_feature] is no_theorem_that_hard_general_sat_has_polynomially_bounded_width_refutations_generated_by_the_operator
