    + [capability] is role_suggestion
    + [capability] is candidate_meaning
    + [capability] is candidate_relation
    + [capability] is faculty_run
    + [capability] is objection
    + [capability] is answer
    + [capability] is jury_review

  & [LocalConfigArtifact] is the checked-in provider set
    + [config] is slm_project/provider_sets/local_provider_set_v0.json
    + [provider] is mock-fixture
    + [provider] is local-lm-studio
    + [provider] is local-ollama

  & [RuntimeProjection] is the Rust source surface
