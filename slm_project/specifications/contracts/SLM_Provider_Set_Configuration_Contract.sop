    + [module] is slm_rust/src/providers.rs ProviderConfig
    + [module] is slm_rust/src/providers.rs ProviderSetConfig
    + [module] is slm_rust/src/providers.rs provider_set_from_json
    + [module] is slm_rust/src/providers.rs validate_provider_set
    + [proof_route] is config parser tests and WSL cargo test

